# =========================
# Project Mercury Specific
# =========================
# Ignore all generated files in the output directory
output/*
# BUT keep the output folder structure intact for cloning
!output/.keep

# Environment variables (CRITICAL: Never commit your actual .env)
.env
.env.*
!.env.example

# =========================
# Python & Environments
# =========================
# Virtual environments
.venv/
venv/
env/
ENV/

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# =========================
# macOS Specific
# =========================
.DS_Store
.AppleDouble
.LSOverride
._*

# =========================
# IDEs & Editors
# =========================
.vscode/
.idea/
*.swp
*.swo