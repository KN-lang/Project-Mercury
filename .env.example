# ── Optional environment overrides ────────────────────────────────────────────
# Copy this file to .env and uncomment/edit what you need.

# Override which Ollama model Mercury uses (default: qwen2.5:0.5b)
# OLLAMA_MODEL=llama3.2:1b

# Override Ollama server address (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Override the MLX Whisper model repo (default: base.en)
# WHISPER_MODEL_REPO=mlx-community/whisper-tiny.en-mlx

# Fallback openai-whisper model if mlx-whisper is unavailable (default: base.en)
# WHISPER_MODEL_FALLBACK=tiny.en
